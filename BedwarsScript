local scanTimer = 0
scan_bee() ; scan_metal() ; scan_elder() ; scan_star()

_G.bw_heartbeat = RunService.Heartbeat:Connect(function(dt)
    scanTimer = scanTimer + dt
    if scanTimer >= 2 then
        scanTimer = 0
        scan_bee() ; scan_metal() ; scan_elder() ; scan_star()
    end
    if cfg.bee.enabled   then update_bee()   end
    if cfg.metal.enabled then update_metal() end
    if cfg.elder.enabled then update_elder() end
    if cfg.star.enabled  then update_star()  end
end)
