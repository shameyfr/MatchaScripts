
if _G.bw_executed then
    for _, info in pairs(_G.bw_bee   or {}) do if info.text then info.text:Remove() end end
    for _, info in pairs(_G.bw_metal or {}) do if info.text then info.text:Remove() end if info.box then info.box:Remove() end end
    for _, info in pairs(_G.bw_elder or {}) do if info.text then info.text:Remove() end if info.box then info.box:Remove() end end
    for _, info in pairs(_G.bw_star  or {}) do if info.text then info.text:Remove() end if info.box then info.box:Remove() end end
    if _G.bw_heartbeat then _G.bw_heartbeat:Disconnect() end
end
_G.bw_executed = true

local beeTracks   = {} ; _G.bw_bee   = beeTracks
local metalTracks = {} ; _G.bw_metal = metalTracks
local elderTracks = {} ; _G.bw_elder = elderTracks
local starTracks  = {} ; _G.bw_star  = starTracks

local RunService = game:GetService("RunService")

local cfg = {
    bee   = { enabled = false, color = Color3.fromRGB(255, 200, 0), maxDist = 300 },
    metal = { enabled = false, color = Color3.fromRGB(180, 180, 180) },
    elder = { enabled = false, color = Color3.fromRGB(180, 180, 180) },
    star  = { enabled = false, color = Color3.fromRGB(180, 180, 180) },
}

local function lerp(a, b, t) return a + (b - a) * t end

local function hide(info)
    if info.text then info.text.Visible = false end
    if info.box  then info.box.Visible  = false end
    info.lastPos = nil
end

local function newText(label, color)
    local t = Drawing.new("Text")
    t.Text = label ; t.Center = true ; t.Outline = true
    t.Color = color ; t.Size = 16 ; t.Visible = false
    return t
end

local function newBox(color)
    local b = Drawing.new("Square")
    b.Thickness = 1 ; b.Filled = false
    b.Color = color ; b.Visible = false
    return b
end

local function scan_bee()
    local valid = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj.Name == "Bee" and obj:IsA("Model") then
            local part = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Part") or obj:FindFirstChildWhichIsA("BasePart")
            if part then
                valid[obj] = true
                if not beeTracks[obj] then
                    beeTracks[obj] = { root = part, text = newText("", cfg.bee.color), lastPos = nil }
                end
            end
        end
    end
    for obj, info in pairs(beeTracks) do
        if not valid[obj] then info.text:Remove() ; beeTracks[obj] = nil end
    end
end

local function update_bee()
    local hrp = (game.Players.LocalPlayer.Character or {}).HumanoidRootPart
    if not hrp then return end
    for _, info in pairs(beeTracks) do
        local root = info.root
        if root and root.Parent then
            local screen, on = WorldToScreen(root.Position)
            local dist = (hrp.Position - root.Position).Magnitude
            if on and dist <= cfg.bee.maxDist then
                local tp = Vector2.new(screen.X, screen.Y)
                if info.lastPos then
                    info.lastPos = Vector2.new(lerp(info.lastPos.X, tp.X, 0.3), lerp(info.lastPos.Y, tp.Y, 0.3))
                else info.lastPos = tp end
                info.text.Position = info.lastPos
                info.text.Text = math.floor(dist) .. "m"
                info.text.Transparency = 1 - (dist / cfg.bee.maxDist)
                info.text.Color = cfg.bee.color
                info.text.Visible = true
            else hide(info) end
        else hide(info) end
    end
end

local function scan_metal()
    local valid = {}
    for _, model in pairs(workspace:GetChildren()) do
        if model:FindFirstChild("hidden-metal-prompt") then
            local part = model:FindFirstChild("Part")
            if part then
                local addr = tostring(part)
                valid[addr] = true
                if not metalTracks[addr] then
                    metalTracks[addr] = { root = part, text = newText("Metal", cfg.metal.color), box = newBox(cfg.metal.color) }
                end
            end
        end
    end
    for addr, info in pairs(metalTracks) do
        if not valid[addr] then info.text:Remove() ; info.box:Remove() ; metalTracks[addr] = nil end
    end
end

local function update_metal()
    for _, info in pairs(metalTracks) do
        local root = info.root
        if root and root.Position then
            local hp, on1 = WorldToScreen(root.Position + Vector3.new(0, 2, 0))
            local lp, on2 = WorldToScreen(root.Position - Vector3.new(0, 2, 0))
            if on1 and on2 then
                local h = math.abs(hp.Y - lp.Y) ; local w = h / 1.5
                info.box.Position = Vector2.new(hp.X - w/2, hp.Y) ; info.box.Size = Vector2.new(w, h)
                info.box.Color = cfg.metal.color ; info.box.Visible = true
                info.text.Position = Vector2.new(hp.X, hp.Y - 16)
                info.text.Color = cfg.metal.color ; info.text.Visible = true
            else hide(info) end
        else hide(info) end
    end
end

