for _, obj in pairs(workspace:GetChildren()) do
    if typeof(obj) == "Instance" then
        addBee(obj)
        task.spawn(function()
            task.wait()
            if typeof(obj) == "Instance" then
                addMetal(obj)
                addElder(obj)
                addStar(obj)
            end
        end)
    end
end

local childAddedOk, childAddedConn = pcall(function()
    return workspace.ChildAdded:Connect(function(obj)
        if typeof(obj) ~= "Instance" then return end
        task.spawn(addBee, obj)
        task.spawn(function()
            task.wait()
            if typeof(obj) == "Instance" then
                addMetal(obj)
                addElder(obj)
                addStar(obj)
            end
        end)
    end)
end)

if childAddedOk then
    table.insert(_G.bw_connections, childAddedConn)
else
    warn("ChildAdded blocked, falling back to polling")
    local scanTimer = 0
    table.insert(_G.bw_connections, RunService.Heartbeat:Connect(function(dt)
        scanTimer = scanTimer + dt
        if scanTimer >= 2 then
            scanTimer = 0
            for _, obj in pairs(workspace:GetChildren()) do
                if typeof(obj) == "Instance" then
                    pcall(addBee, obj)
                    pcall(addMetal, obj)
                    pcall(addElder, obj)
                    pcall(addStar, obj)
                end
            end
        end
    end))
end

local childRemovedOk, childRemovedConn = pcall(function()
    return workspace.ChildRemoved:Connect(function(obj)
        removeBee(obj)
        removeMetal(obj)
        removeElder(obj)
        removeStar(obj)
    end)
end)

if childRemovedOk then
    table.insert(_G.bw_connections, childRemovedConn)
end

