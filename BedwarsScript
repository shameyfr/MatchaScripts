local function lerp(a, b, t) return a + (b - a) * t end

local function hide(info)
    if info.text then info.text.Visible = false end
    if info.box  then info.box.Visible  = false end
    info.lastPos = nil
end

local function newText(label, color)
    local t = Drawing.new("Text")
    t.Text = label ; t.Center = true ; t.Outline = true
    t.Color = color ; t.Size = 16 ; t.Visible = false
    return t
end

local function newBox(color)
    local b = Drawing.new("Square")
    b.Thickness = 1 ; b.Filled = false
    b.Color = color ; b.Visible = false
    return b
end

local function getHRP()
    local c = game.Players.LocalPlayer.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function addBee(obj)
    if typeof(obj) ~= "Instance" then return end
    if not (obj.Name == "Bee" and obj:IsA("Model")) then return end
    local part = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Part") or obj:FindFirstChildWhichIsA("BasePart")
    if part and not beeTracks[obj] then
        beeTracks[obj] = { root = part, text = newText("", cfg.bee.color), box = newBox(cfg.bee.color), lastPos = nil }
    end
end

local function removeBee(obj)
    if beeTracks[obj] then
        beeTracks[obj].text:Remove() ; beeTracks[obj].box:Remove()
        beeTracks[obj] = nil
    end
end

local function update_bee()
    local hrp = getHRP()
    if not hrp then return end
    for obj, info in pairs(beeTracks) do
        local root = info.root
        if not cfg.bee.enabled then hide(info)
        elseif not root or not root.Parent or not root.Position then
            hide(info)
            beeTracks[obj] = nil
        else
            local dist = (hrp.Position - root.Position).Magnitude
            if dist > cfg.bee.maxDist then hide(info) ; continue end
            local screen, on = WorldToScreen(root.Position)
            if on then
                local tp = Vector2.new(screen.X, screen.Y)
                if info.lastPos then
                    info.lastPos = Vector2.new(lerp(info.lastPos.X, tp.X, 0.3), lerp(info.lastPos.Y, tp.Y, 0.3))
                else info.lastPos = tp end
                local hp, on1 = WorldToScreen(root.Position + Vector3.new(0, 2, 0))
                local lp, on2 = WorldToScreen(root.Position - Vector3.new(0, 2, 0))
                if on1 and on2 and cfg.bee.box then
                    local h = math.abs(hp.Y - lp.Y) ; local w = h / 1.5
                    info.box.Position = Vector2.new(hp.X - w/2, hp.Y)
                    info.box.Size = Vector2.new(w, h)
                    info.box.Color = cfg.bee.color
                    info.box.Visible = true
                else info.box.Visible = false end
                local label = ""
                if cfg.bee.name then label = "Bee" end
                if cfg.bee.distance then label = label .. (cfg.bee.name and "\n" or "") .. math.floor(dist) .. "m" end
                info.text.Position = info.lastPos
                info.text.Color = cfg.bee.color
                info.text.Transparency = 1 - (dist / cfg.bee.maxDist)
                info.text.Text = label
                info.text.Visible = label ~= ""
            else hide(info) end
        end
    end
end

